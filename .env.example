# ── LLM Providers ─────────────────────────────────────────────────────
# OpenAI — required for text (gpt-4o-mini) and vision (gpt-4o)
OPENAI_API_KEY=sk-...

# Google Gemini — optional, only needed if TEXT_LLM_PROVIDER=gemini
GEMINI_API_KEY=

# ── LLM Provider Selection ────────────────────────────────────────────
# Which provider to use for text generation: openai / gemini
TEXT_LLM_PROVIDER=openai

# Which provider to use for vision/photo evaluation: openai / qwen_local
VISION_LLM_PROVIDER=openai

# ── Model Overrides (optional) ────────────────────────────────────────
# Defaults shown — override only if needed
TEXT_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o

# ── Backend Server ────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
